<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingHorizontal="16dp"
    android:paddingVertical="8dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/epg_url"
        android:textColor="@color/text_secondary"
        android:textSize="14sp" />

    <EditText
        android:id="@+id/epg_url_input"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/channel_item_bg"
        android:hint="http://example.com/epg.xml"
        android:inputType="textUri"
        android:padding="12dp"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_secondary"
        android:textSize="14sp" />

    <Button
        android:id="@+id/btn_save_epg"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:backgroundTint="@color/primary"
        android:paddingHorizontal="20dp"
        android:text="@string/save_epg_settings"
        android:textColor="@color/text_primary" />

    <Button
        android:id="@+id/btn_reload_epg"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:backgroundTint="@color/card_focused"
        android:paddingHorizontal="20dp"
        android:text="@string/reload_epg_data"
        android:textColor="@color/text_primary" />

</LinearLayout>
